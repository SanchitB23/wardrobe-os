# Supabase (client-safe — bundled to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider selection (legacy single-provider path used by getServerAIService /
# vision). Only "gemini" is implemented today.
AI_PROVIDER=gemini

# Gemini (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_, never commit a real key).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash (chosen for low cost).
GEMINI_MODEL=gemini-2.5-flash

# --- AI Runtime v2 (RFC-014 / RFC-014A) — capability-based provider routing ----
# The AI Runtime routes each capability to a provider policy: primary → fallback
# (+ retry). The shipped default (RFC-014A) is OpenAI-primary with a Gemini
# fallback for text/reasoning (EXPLANATION, SUMMARIZATION, CONVERSATION); VISION
# and IMAGE_GENERATION stay Gemini-only. Override per capability with
# AI_POLICY_<CAPABILITY>="primary[,fallback]" (providers: gemini | openai |
# claude). Capabilities: EXPLANATION, SUMMARIZATION, CONVERSATION, VISION,
# IMAGE_GENERATION, EMBEDDINGS. Example (matches the default):
# AI_POLICY_EXPLANATION=openai,gemini
# AI_POLICY_CONVERSATION=openai,gemini
# AI_POLICY_SUMMARIZATION=openai,gemini
# AI_POLICY_VISION=gemini
# AI_POLICY_IMAGE_GENERATION=gemini

# OpenAI (RFC-014A — SERVER-SIDE ONLY; never prefix with NEXT_PUBLIC_, never commit
# a real key). If OPENAI_API_KEY is BLANK the OpenAI provider is unavailable and
# the runtime transparently falls back to Gemini — safe to leave empty locally.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model overrides. Text/reasoning → OPENAI_MODEL_TEXT; JSON/structured
# output → OPENAI_MODEL_STRUCTURED.
OPENAI_MODEL_TEXT=gpt-5.5
OPENAI_MODEL_STRUCTURED=gpt-5.4-mini

# Application Access Guard (RFC-010 — SERVER-SIDE ONLY; not authentication).
# The single shared code that gates the whole app. Leave BLANK to disable the
# guard (e.g. local dev). Set it in every deployed environment.
APP_ACCESS_CODE=
# HMAC secret used to sign the access cookie. Required whenever APP_ACCESS_CODE
# is set. Use a long random value (e.g. `openssl rand -base64 48`). Rotating it
# invalidates all existing sessions.
APP_COOKIE_SECRET=
