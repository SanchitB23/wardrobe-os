# Supabase (client-safe — bundled to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider selection (legacy single-provider path used by getServerAIService /
# vision). Only "gemini" is implemented today.
AI_PROVIDER=gemini

# Gemini (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_, never commit a real key).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash (chosen for low cost).
GEMINI_MODEL=gemini-2.5-flash

# --- AI Runtime v2 (RFC-014 / RFC-014A) — cost-first capability routing --------
# The AI Runtime routes each capability to a provider policy: primary → fallback
# (+ retry). Cost-first default (RFC-014A): GEMINI is primary for conversation,
# explanation, summarization, and vision; OPENAI is used selectively for cheap,
# high-value STRUCTURED + CLASSIFICATION tasks (Gemini fallback). Override per
# capability with AI_POLICY_<CAPABILITY>="primary[,fallback]" (providers:
# gemini | openai | claude). Capabilities: CONVERSATION, EXPLANATION,
# SUMMARIZATION, STRUCTURED, CLASSIFICATION, VISION, IMAGE_GENERATION, EMBEDDINGS.
# Examples (match the shipped default):
# AI_POLICY_CONVERSATION=gemini,openai
# AI_POLICY_EXPLANATION=gemini,openai
# AI_POLICY_SUMMARIZATION=gemini,openai
# AI_POLICY_STRUCTURED=openai,gemini
# AI_POLICY_CLASSIFICATION=openai,gemini
# AI_POLICY_VISION=gemini
# AI_POLICY_IMAGE_GENERATION=openai,gemini

# OpenAI (RFC-014A — SERVER-SIDE ONLY; never prefix with NEXT_PUBLIC_, never commit
# a real key). OpenAI is OPTIONAL: if OPENAI_API_KEY is BLANK the provider is
# unavailable and the runtime transparently falls back to Gemini (zero OpenAI
# spend) — safe to leave empty. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model policy (per capability). Nano for classification, Mini for structured/text.
# GPT-5.5 is a future/premium option and is NEVER used by default.
OPENAI_MODEL_TEXT=gpt-5.4-mini
OPENAI_MODEL_STRUCTURED=gpt-5.4-mini
OPENAI_MODEL_CLASSIFIER=gpt-5.4-nano
OPENAI_MODEL_PREMIUM=gpt-5.5
# Vision fallback model (RFC-029). Any multimodal GPT-5 model; mini is cost-first.
# Only used when Gemini vision fails AND OPENAI_API_KEY is set + budget available.
OPENAI_MODEL_VISION=gpt-5.4-mini

# OpenAI budget guard (RFC-014A). Estimated month-to-date spend is tracked from
# token usage; at the hard stop OpenAI is marked unavailable and routing falls
# back to Gemini (Gemini is never blocked). Best-effort; resets on restart.
OPENAI_MONTHLY_BUDGET_USD=5
OPENAI_SOFT_ALERT_USD=2
OPENAI_HARD_STOP_USD=5

# Application Access Guard (RFC-010 — SERVER-SIDE ONLY; not authentication).
# The single shared code that gates the whole app. Leave BLANK to disable the
# guard (e.g. local dev). Set it in every deployed environment.
APP_ACCESS_CODE=
# HMAC secret used to sign the access cookie. Required whenever APP_ACCESS_CODE
# is set. Use a long random value (e.g. `openssl rand -base64 48`). Rotating it
# invalidates all existing sessions.
APP_COOKIE_SECRET=

# --- Logging & Observability (RFC-022) ----------------------------------------
# Structured JSON logs → stdout (Vercel Runtime Logs). Observability observes;
# it does not change routing, scoring, or business outcomes.
LOG_LEVEL=info
LOG_AI_USAGE=true
LOG_REQUESTS=true
LOG_ENGINE_TRACES=false
LOG_REDACTED=true
# Dev-only: capture sanitized API metadata for /developer/replay (never in prod)
# REPLAY_CAPTURE=true
