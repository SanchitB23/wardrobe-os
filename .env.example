# Supabase (client-safe — bundled to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider selection. Only "gemini" is implemented today.
AI_PROVIDER=gemini

# Gemini (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_, never commit a real key).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash (chosen for low cost).
GEMINI_MODEL=gemini-2.5-flash
