# =============================================================================
# Wardrobe OS — PRODUCTION non-sensitive config (safe to commit / import)
# -----------------------------------------------------------------------------
# These are the NON-SENSITIVE values (models, budgets, logging). Import this file
# into Vercel → Project → Settings → Environment Variables → Import, targeting the
# Production environment.
#
# Secrets are intentionally NOT in this file (so importing can't blank them out).
# Set the ones under "SECRETS" below manually in Vercel, Production scope, once.
# =============================================================================

# --- Provider selection -------------------------------------------------------
AI_PROVIDER=gemini

# --- Gemini model (key is a secret; see SECRETS) ------------------------------
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI model policy (key is a secret; see SECRETS) -----------------------
# Cost-first: mini for text/structured/vision, nano for classification.
# gpt-5.5 (premium) is never used by default.
OPENAI_MODEL_TEXT=gpt-5.4-mini
OPENAI_MODEL_STRUCTURED=gpt-5.4-mini
OPENAI_MODEL_CLASSIFIER=gpt-5.4-nano
OPENAI_MODEL_PREMIUM=gpt-5.5
OPENAI_MODEL_VISION=gpt-5.4-mini

# --- OpenAI budget guard ------------------------------------------------------
# At the hard stop OpenAI is marked unavailable and routing (and vision fallback)
# falls back to Gemini. Gemini is never blocked.
OPENAI_MONTHLY_BUDGET_USD=5
OPENAI_SOFT_ALERT_USD=2
OPENAI_HARD_STOP_USD=5

# --- Logging & observability --------------------------------------------------
LOG_LEVEL=info
LOG_AI_USAGE=true
LOG_REQUESTS=true
LOG_ENGINE_TRACES=false
LOG_REDACTED=true
# REPLAY_CAPTURE is dev-only — never enable in production.

# =============================================================================
# SECRETS — do NOT put values here. Set these manually in Vercel (Production):
#   GEMINI_API_KEY               server-side Gemini key
#   OPENAI_API_KEY               server-side OpenAI key (optional; blank ⇒ Gemini-only)
#   APP_ACCESS_CODE              shared access-guard code
#   APP_COOKIE_SECRET            HMAC secret for the access cookie (openssl rand -base64 48)
#   NEXT_PUBLIC_SUPABASE_URL     project URL (public, but project-specific)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  publishable anon key (public, but project-specific)
# VERCEL_OIDC_TOKEN is managed automatically by Vercel — do not set it.
# =============================================================================
